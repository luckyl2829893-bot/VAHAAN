# --- Aequitas-RoadGuard .gitignore ---

# Python Environment and Cache
ARGvenv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Large Models and Weights (Ignored to keep repo light)
*.pt
*.m.pt
*.weights

# Multimedia Data (Ignored)
*.mp4
*.avi
*.mov
*.mkv
*.jpg
*.png
*.jpeg
*.gif
*.zip
*.rar
*.7z

# Data Directories (Heavily restricted)
data/
models/
scratch/
annotation_staging/
label_verification/
label_verification_stage2/
rules for no plates/
backup/
images/
plate_dataset/
vehicle_dataset/
annotated_data/
compiled_training_data/
evidence_vault/
arg_engine_output/
data_csv/
data_pipeline/train/
data_pipeline/incoming_plates/
test_images_outputs/
test_outputs/
videos_structured/
runs/

# Growth logs and large JSONs
*.jsonl
*.csv

# Database files
*.sqlite
*.db

# OS and IDE files
.gemini/
.idea/
.vscode/
.DS_Store
Thumbs.db

# --- TRACKED FILES (FOR REFERENCE) ---
# We make sure code and documentation are explicitly tracked.
!README.md
!PROJECT_GUIDE.md
!ARG_Master_Blueprint.md
!ARG_Developer_Log.md
!arg_mlops_audit_and_roadmap.md
!requirements.txt
